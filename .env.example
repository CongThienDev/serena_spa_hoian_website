# ─────────────────────────────────────────────
# Serena Spa Hội An — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────

# Site
NEXT_PUBLIC_SITE_URL=https://serenaspahoian.com
NEXT_PUBLIC_SITE_NAME="Serena Spa Hội An"

# Booking Notification — Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Email Notifications — Resend (future migration from Telegram)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=booking@serenaspahoian.com
RESEND_TO_EMAIL=info@serenaspahoian.com

# Sanity CMS (Phase 9 — defer until CMS integration)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=your_sanity_api_token

# Analytics — Umami (self-hosted, optional)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id
NEXT_PUBLIC_UMAMI_URL=https://analytics.serenaspahoian.com

# Anti-spam (future — Cloudflare Turnstile)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
# TURNSTILE_SECRET_KEY=your_turnstile_secret_key
